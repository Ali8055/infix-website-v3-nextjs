# ─────────────────────────────────────────────────────────────────
#  Infix Systems — Contact Form Environment Variables
#  Copy this file to .env.local and fill in your real values.
#  NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# The Gmail address that Nodemailer will authenticate as and send FROM.
# e.g. yourcompany@gmail.com  or  noreply@yourdomain.com (if hosted on Google Workspace)
GMAIL_USER=your-sender@gmail.com

# A Google "App Password" — NOT your regular Gmail password.
# How to generate one:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification (required)
#   3. Go to myaccount.google.com/apppasswords
#   4. Select app: "Mail" | Select device: "Other (Custom name)" → give it a name like "Infix Contact Form"
#   5. Copy the 16-character password (spaces are optional, the API ignores them)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# The email address that should RECEIVE the contact form submissions.
# Can be the same as GMAIL_USER, or a different inbox (e.g. info@infixsystems.com).
CONTACT_RECIPIENT_EMAIL=info@infixsystems.com
